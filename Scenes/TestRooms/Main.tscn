[sub_resource type="GDScript" id="GDScript_epx8f"]
script/source = "extends CanvasLayer
var escapeMenu :Node

# Called when the node enters the scene tree for the first time.
func _ready() -> void:
	escapeMenu = get_parent().get_node(\"UI/Escape\")
	print(\"DEBUG -- escape node: \" , escapeMenu)
	

"

